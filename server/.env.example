# DATABASE
DATABASE_URL=postgresql://user:password@localhost:5432/vector?schema=public

# REDIS
REDIS_URL=redis://localhost:6379

# APP
PORT=8080
NODE_ENV=development
# Consolidated: APP_URL is the primary dashboard/frontend URL
APP_URL=https://dashboard.vector-logistics.com

# JWT
JWT_ACCESS_SECRET=super-secret-access-key
JWT_REFRESH_SECRET=super-secret-refresh-key
JWT_ACCESS_EXPIRATION=1h
JWT_REFRESH_EXPIRATION=7d

# PAYSTACK
PAYSTACK_SECRET_KEY=sk_test_your_secret_key
PAYSTACK_PUBLIC_KEY=pk_test_your_public_key

# SENDGRID EMAIL
SENDGRID_API_KEY=SG.your_api_key_here
SENDER_EMAIL=notifications@vector.com

# GEO
GEOAPIFY_API_KEY=your_geoapify_key

# CLOUDINARY
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_UPLOAD_PRESET=your_upload_preset_here

# FIREBASE
GOOGLE_APPLICATION_CREDENTIALS=firebase-service-account.json
